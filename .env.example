PORT=5000
NODE_ENV=development
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Clé service_role (optionnel) : pour charger les photos depuis un bucket privé dans les PDF
# À configurer dans Supabase : Settings > API > service_role secret
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Activer l'authentification obligatoire sur les routes API (panneaux, photos, etc.)
# Si "true", toutes les requêtes doivent inclure: Authorization: Bearer <token>
# Si absent ou "false", les routes restent accessibles sans token
AUTH_REQUIRED=false

# Mapbox (optionnel) : pour afficher la carte des zones dans les rapports PDF
# Créer un token sur https://account.mapbox.com/ - 100k requêtes/mois gratuites
# MAPBOX_ACCESS_TOKEN=pk.xxx

# Debug PDF : activer les logs pour diagnostiquer le chargement des photos
# DEBUG_PDF=true

# CORS : origines autorisées (séparées par des virgules)
# Par défaut : localhost pour dev. En prod, ajouter l'URL de l'admin et du mobile web
# CORS_ORIGINS=https://admin.votredomaine.com,https://app.votredomaine.com
# Exemple prod Railway :
# NODE_ENV=production
# CORS_ORIGINS=https://billboardeye-admin.vercel.app,https://billboardeye-app.vercel.app

# Auto-CORS prod (si CORS_ORIGINS est vide)
# ADMIN_WEB_URL=https://billboardeye-admin.vercel.app
# MOBILE_WEB_URL=https://billboardeye-app.vercel.app
# FRONTEND_URL=https://billboardeye.vercel.app
# PUBLIC_WEB_URL=https://app.votredomaine.com

# ─── PDF campagne = rendu identique à tmp_v0_template (Next + Puppeteer) ───
# OBLIGATOIRE en production : même valeur pour l’API et le process Next (start-with-renderer).
# PDF_RENDER_INTERNAL_SECRET=changez-moi-long-secret-aleatoire
#
# URL interne de l’API (défaut http://127.0.0.1:$PORT) — utilisée par Next pour charger les données.
# BILLBOARD_API_INTERNAL_URL=http://127.0.0.1:5000
#
# URL du serveur Next standalone (défaut http://127.0.0.1:3001) — utilisée par Puppeteer.
# REPORT_RENDERER_BASE_URL=http://127.0.0.1:3001
#
# Port du renderer Next (défaut 3001)
# REPORT_RENDERER_PORT=3001
#
# Forcer l’ancien HTML inline (sans Next) :
# DISABLE_NEXT_PDF_RENDERER=true
