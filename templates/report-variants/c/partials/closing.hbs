<section class="pdf-page rv-c-page rv-c-close">
  <div class="rv-c-rule-t"></div>
  <div class="rv-c-close-inner">
    <div class="rv-c-brand-row">
      <span class="rv-c-dot"></span>
      <span class="rv-c-brand-w">{{footerBrand}}</span>
    </div>
    <div class="rv-c-close-mid">
      <div class="rv-c-rule-s"></div>
      <p class="rv-c-close-ey">Clôture du rapport</p>
      <h2 class="rv-c-close-h">{{closingHeading}}</h2>
      <div class="rv-c-divider-w"></div>
      <p class="rv-c-close-p">{{closingBody}}</p>
      <div class="rv-c-sig">
        <p class="rv-c-sig-l">{{closingSignatureLabel}}</p>
        <p class="rv-c-sig-v">{{closingSignatureValue}}</p>
      </div>
    </div>
    <div class="rv-c-foot rv-c-foot-dark">
      <span class="rv-c-foot-b">{{footerBrand}}</span>
      <span class="rv-c-foot-n">{{footerNote}}</span>
      <span class="rv-c-foot-d">{{date}}</span>
    </div>
  </div>
  <div class="rv-c-rule-b"></div>
</section>
