<section class="pdf-page rv-b-page rv-b-close">
  <div class="rv-b-accentbar"></div>
  <div class="rv-b-close-inner">
    <div class="rv-b-close-top">
      <span class="rv-b-brand">{{footerBrand}}</span>
      <span class="rv-b-close-lbl">Clôture du rapport</span>
    </div>
    <div class="rv-b-close-box">
      <p class="rv-b-close-ey">Conclusion</p>
      <h2 class="rv-b-close-h">{{closingHeading}}</h2>
      <p class="rv-b-close-p">{{closingBody}}</p>
      <div class="rv-b-sigbox">
        <div class="rv-b-sigbar"></div>
        <div>
          <p class="rv-b-sig-l">{{closingSignatureLabel}}</p>
          <p class="rv-b-sig-v">{{closingSignatureValue}}</p>
        </div>
      </div>
    </div>
    <div class="rv-b-foot rv-b-foot-dark">
      <span class="rv-b-foot-b">{{footerBrand}}</span>
      <span class="rv-b-foot-n">{{footerNote}}</span>
      <span class="rv-b-foot-d">{{date}}</span>
    </div>
  </div>
</section>
