<section class="pdf-page rv-a-page rv-a-closing">
  <div class="rv-a-accentbar"></div>
  <div class="rv-a-close-inner">
    <div class="rv-a-close-top">
      <p class="rv-a-eyebrow-sm">Clôture du rapport</p>
      <div class="rv-a-hr"></div>
    </div>
    <div class="rv-a-close-center">
      <div class="rv-a-rule"></div>
      <h2 class="rv-a-close-title">{{closingHeading}}</h2>
      <p class="rv-a-close-body">{{closingBody}}</p>
      <div class="rv-a-sig">
        <p class="rv-a-sig-lbl">{{closingSignatureLabel}}</p>
        <p class="rv-a-sig-val">{{closingSignatureValue}}</p>
      </div>
    </div>
    <div class="rv-a-foot">
      <span class="rv-a-foot-brand">{{footerBrand}}</span>
      <span class="rv-a-foot-note">{{footerNote}}</span>
      <span class="rv-a-foot-date">{{date}}</span>
    </div>
  </div>
</section>
