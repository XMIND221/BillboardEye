{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "production-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_RAILWAY_API_URL": "https://billboardeye-production.up.railway.app/api",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_RAILWAY_API_URL": "https://billboardeye-production.up.railway.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
