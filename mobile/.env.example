# Évite l’erreur Windows « Body has already been read » au démarrage (validation des deps Expo).
# Déjà défini dans les scripts npm ; optionnel si tu lances `npx expo start` à la main.
# EXPO_NO_DEPENDENCY_VALIDATION=1

EXPO_PUBLIC_API_BASE_URL=https://billboardeye-production.up.railway.app/api

# Pour l'authentification Supabase (login/register)
# Si définis, l'app affichera l'écran de connexion avant le choix de rôle
EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optionnel: IP locale pour dev (téléphone et PC sur le même Wi-Fi)
EXPO_PUBLIC_LOCAL_IP=192.168.1.86
