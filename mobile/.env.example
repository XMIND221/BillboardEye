# ── Copier en .env ; pour lancer Expo voir aussi EXPO_DEMARRAGE.md ──
# Sous Windows / Node récent : évite l’erreur « Body is unusable » au `expo start`
EXPO_NO_DEPENDENCY_VALIDATION=1

# L’URL de l’API est **Railway par défaut** dans le code (aucune ligne API requise).

# Obligatoire pour la connexion (Supabase → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Autre URL Railway (sinon = valeur dans src/constants/railway.js) :
# EXPO_PUBLIC_RAILWAY_API_URL=https://ton-service.up.railway.app/api

# API locale seulement si tu lances le serveur Node sur ton PC :
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api
# (L’app remplace localhost : émulateur Android → 10.0.2.2 ; téléphone → IP détectée via Expo quand c’est possible.)

# EXPO_PUBLIC_LOCAL_IP=192.168.x.x   # repli si la détection Expo ne donne pas l’IP
# EXPO_PUBLIC_FORCE_ANDROID_EMULATOR=1   # si l’émulateur est mal détecté
