{
  "expo": {
    "name": "BillboardEye",
    "slug": "billboardeye-mobile",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1C2E"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.billboardeye.mobile",
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "c9cbd8e8-29e7-40b7-8785-9d4b49d551fa"
      }
    }
  }
}
